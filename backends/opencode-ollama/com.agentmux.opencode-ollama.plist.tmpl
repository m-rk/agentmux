<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agentmux.opencode-ollama</string>

    <key>ProgramArguments</key>
    <array>
        <string>@@REPO_DIR@@/rc-start.sh</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>StartInterval</key>
    <integer>@@START_INTERVAL@@</integer>

    <key>EnvironmentVariables</key>
    <dict>
        <key>AGENTMUX_SESSION_NAME</key>
        <string>@@TMUX_SESSION_NAME@@</string>
        <key>AGENTMUX_TMUX_SESSION_NAME</key>
        <string>@@TMUX_SESSION_NAME@@</string>
        <key>AGENTMUX_WORKDIR</key>
        <string>@@WORKDIR@@</string>
        <key>AGENTMUX_OLLAMA_MODEL</key>
        <string>@@OLLAMA_MODEL@@</string>
        <key>AGENTMUX_OLLAMA_WAIT_SECONDS</key>
        <string>@@OLLAMA_WAIT_SECONDS@@</string>
        <key>HOME</key>
        <string>@@HOME@@</string>
        <key>PATH</key>
        <string>@@PATH@@</string>
    </dict>

    <key>StandardOutPath</key>
    <string>@@LOG_DIR@@/opencode-ollama.log</string>
    <key>StandardErrorPath</key>
    <string>@@LOG_DIR@@/opencode-ollama.err.log</string>
</dict>
</plist>
